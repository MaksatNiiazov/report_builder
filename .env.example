APP_NAME=TURKUAZ Report Builder
APP_ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/report_builder.db
AUTO_CREATE_SCHEMA=false
BACKEND_CORS_ORIGINS=http://localhost:7505,http://127.0.0.1:7505
AUTH_ENABLED=true
IDENTITY_SECRET_KEY=dev-change-me-32-byte-secret-key-for-turkuaz-identity
IDENTITY_ALGORITHM=HS256
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REPORT_SOURCE_ENCRYPTION_KEY=
QUERY_TIMEOUT_SECONDS=20
PREVIEW_ROW_LIMIT=200
ABSOLUTE_ROW_LIMIT=50000
MAX_CONCURRENT_QUERIES=4

